{
  "name": "oauthlint",
  "version": "0.1.0",
  "private": true,
  "description": "OAuthLint — Semgrep rule pack + CLI + GitHub Action + VS Code extension catching the OAuth/OIDC/JWT anti-patterns AI coding tools systematically produce.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:run": "pnpm -r run test:run && pnpm test:scripts",
    "test:scripts": "vitest run --config scripts/vitest.config.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r exec rm -rf dist node_modules .turbo",
    "scan:self": "node cli/bin/oauthlint.js scan ./examples",
    "validate": "tsx scripts/validate-rules.ts",
    "bench": "tsx benchmark/run.ts",
    "prepare": "husky",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "lint-staged": {
    "*.{ts,js,json,jsonc}": ["biome check --write --no-errors-on-unmatched"],
    "*.{yml,yaml,md}": ["biome format --write --no-errors-on-unmatched"]
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@vitest/coverage-v8": "2.1.9",
    "execa": "9.6.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "oauthlint-rules": "workspace:*",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "2.1.9",
    "yaml": "2.9.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.26.2",
  "author": "Auspeo (https://github.com/Auspeo)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Auspeo/oauthlint.git"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
  }
}

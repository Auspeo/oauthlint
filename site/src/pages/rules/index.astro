---
import SiteChrome from '../../components/SiteChrome.astro';
import Base from '../../layouts/Base.astro';
import { type Severity, getRules } from '../../lib/rules';

const rules = getRules();

// Derive filter options from the data — nothing frozen in prose.
const langOptions = [...new Set(rules.flatMap((r) => r.languages))].sort();
const catOptions = [...new Set(rules.map((r) => r.category))].sort();

// Severity presentation: token names + label, keyed by design severity.
const SEV: Record<Severity, { label: string; color: string }> = {
  critical: { label: 'CRITICAL', color: 'var(--ol-sev-critical)' },
  high: { label: 'HIGH', color: 'var(--ol-sev-high)' },
  medium: { label: 'MEDIUM', color: 'var(--ol-sev-medium)' },
  low: { label: 'LOW', color: 'var(--ol-sev-low)' },
  info: { label: 'INFO', color: 'var(--ol-sev-info)' },
};

// Severity chips, only for severities actually present, in ramp order.
const sevOrder: Severity[] = ['critical', 'high', 'medium', 'low', 'info'];
const presentSevs = sevOrder.filter((s) => rules.some((r) => r.severity === s));

// AI (LLM) prevalence — our core differentiator. HIGH means AI coding tools
// produce this anti-pattern by default. Present as a filter + per-row signal.
type Prevalence = 'HIGH' | 'MEDIUM' | 'LOW';
const prevOrder: Prevalence[] = ['HIGH', 'MEDIUM', 'LOW'];
const PREV: Record<Prevalence, { label: string; color: string }> = {
  HIGH: { label: 'HIGH', color: 'var(--ol-sev-critical)' },
  MEDIUM: { label: 'MEDIUM', color: 'var(--ol-sev-high)' },
  LOW: { label: 'LOW', color: 'var(--ol-text-muted)' },
};
const presentPrevs = prevOrder.filter((p) => rules.some((r) => r.llmPrevalence === p));

// Dataflow (taint) rules — OAuthLint's technical differentiator: these rules
// trace untrusted/sensitive data from a source to a dangerous sink (taint
// mode) rather than matching a single line. The rule loader (`lib/rules.ts`)
// does not yet surface each rule's analysis `mode`, so we derive the taint set
// here, read-only, from the shipped rule ids. Keep in sync with the rules that
// carry `mode: taint` in their YAML (10 today: open-redirect, SSRF and
// secret-in-response across JS/TS, Python and Go, plus the OAuth callback
// open-redirect). Wiring `mode` into RuleView would let this be data-driven.
const TAINT_RULE_IDS = new Set<string>([
  'auth.flow.open-redirect',
  'auth.flow.secret-in-response',
  'auth.flow.ssrf',
  'auth.go.flow.open-redirect',
  'auth.go.flow.secret-in-response',
  'auth.go.flow.ssrf',
  'auth.oauth.open-redirect-callback',
  'auth.py.flow.open-redirect',
  'auth.py.flow.secret-in-response',
  'auth.py.flow.ssrf',
]);
const isTaint = (id: string): boolean => TAINT_RULE_IDS.has(id);
const taintCount = rules.filter((r) => isTaint(r.id)).length;
---
<Base
  title="Rules — OAuthLint"
  description="Browse the OAuthLint rule pack. Filter auth anti-pattern rules by language, category and severity. Every rule maps to a CWE and ships a vulnerable and a safe example."
>
  <SiteChrome active="rules">
    <main style="max-width:1120px; margin:0 auto; padding:var(--ol-space-12) var(--ol-space-6) var(--ol-space-20);">
      <div style="display:flex; align-items:center; gap:10px; margin-bottom:var(--ol-space-3);">
        <span style="width:6px; height:6px; background:var(--ol-accent);"></span>
        <span style="font-family:var(--ol-font-mono); font-size:11px; font-weight:500; letter-spacing:0.14em; color:var(--ol-text-muted);">RULES CATALOGUE</span>
      </div>
      <h1 style="font-family:var(--ol-font-display); font-weight:700; font-size:var(--ol-text-display-l); letter-spacing:-0.03em; margin:0 0 var(--ol-space-4);">Every rule earns its place.</h1>
      <p style="font-size:var(--ol-text-body-l); line-height:var(--ol-leading-relaxed); color:var(--ol-text-secondary); max-width:60ch; margin:0 0 var(--ol-space-5);">Each rule maps to a CWE and ships a vulnerable and a safe example. Filter by language, category, severity — or by how often AI coding tools generate it.</p>
      <div style="display:flex; align-items:center; gap:var(--ol-space-4); flex-wrap:wrap; margin:0 0 var(--ol-space-8);">
        <a href="/owasp" style="display:inline-flex; align-items:center; gap:7px; font-family:var(--ol-font-mono); font-size:12px; color:var(--ol-accent); text-decoration:none;">OWASP coverage →</a>
        <span style="font-family:var(--ol-font-mono); font-size:11px; color:var(--ol-text-faint);">AI prevalence = how often Copilot / Cursor / Claude generate the anti-pattern by default</span>
      </div>

      <!-- DATAFLOW EXPLAINER -->
      {taintCount > 0 && (
        <div style="display:flex; align-items:flex-start; gap:12px; border:1px solid var(--ol-border-strong); border-left:3px solid var(--ol-accent); background:var(--ol-surface); padding:14px 16px; margin:0 0 var(--ol-space-6); max-width:80ch;">
          <svg width="20" height="12" viewBox="0 0 20 12" fill="none" aria-hidden="true" style="flex:none; margin-top:3px; color:var(--ol-accent);">
            <circle cx="3" cy="6" r="2.2" fill="currentColor"></circle>
            <path d="M5.4 6h8.2" stroke="currentColor" stroke-width="1.3"></path>
            <path d="M12.6 2.6L16.4 6l-3.8 3.4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" fill="none"></path>
          </svg>
          <p style="font-size:var(--ol-text-body-s); line-height:1.6; color:var(--ol-text-secondary); margin:0;"><span style="color:var(--ol-text); font-weight:600;">Dataflow analysis.</span> {taintCount} rules run in dataflow (taint) mode — OAuthLint traces untrusted input and sensitive data from source to a dangerous sink, catching multi-line bugs that pattern rules miss. <a href="/research" style="color:var(--ol-accent); text-decoration:none; white-space:nowrap;">See the proof →</a></p>
        </div>
      )}

      <!-- FILTER BAR -->
      <div style="display:flex; flex-wrap:wrap; gap:var(--ol-space-3); align-items:center; margin-bottom:var(--ol-space-5);">
        <div style="display:flex; align-items:center; gap:10px; height:40px; padding:0 12px; background:var(--ol-surface); border:1px solid var(--ol-border-strong); flex:1; min-width:200px;">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--ol-text-muted)" stroke-width="1.6" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="M21 21l-5-5"></path></svg>
          <input id="rule-search" type="search" placeholder="Search rule id or title…" aria-label="Search rules" style="flex:1; min-width:0; background:transparent; border:none; outline:none; color:var(--ol-text); font-family:var(--ol-font-mono); font-size:13px;" />
        </div>
        <select id="rule-lang" aria-label="Filter by language" style="height:40px; padding:0 30px 0 12px; background:var(--ol-surface) url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 fill=%22none%22 stroke=%22%236b7480%22 stroke-width=%222%22><path d=%22M2 4l4 4 4-4%22/></svg>') no-repeat right 12px center; border:1px solid var(--ol-border-strong); color:var(--ol-text); font-family:var(--ol-font-mono); font-size:12px; cursor:pointer; appearance:none; -webkit-appearance:none; -moz-appearance:none;">
          <option value="all">All languages</option>
          {langOptions.map((o) => <option value={o}>{o}</option>)}
        </select>
        <select id="rule-cat" aria-label="Filter by category" style="height:40px; padding:0 30px 0 12px; background:var(--ol-surface) url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 fill=%22none%22 stroke=%22%236b7480%22 stroke-width=%222%22><path d=%22M2 4l4 4 4-4%22/></svg>') no-repeat right 12px center; border:1px solid var(--ol-border-strong); color:var(--ol-text); font-family:var(--ol-font-mono); font-size:12px; cursor:pointer; appearance:none; -webkit-appearance:none; -moz-appearance:none;">
          <option value="all">All categories</option>
          {catOptions.map((o) => <option value={o}>{o}</option>)}
        </select>
        <select id="rule-prevalence" aria-label="Filter by AI prevalence" style="height:40px; padding:0 30px 0 12px; background:var(--ol-surface) url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 fill=%22none%22 stroke=%22%236b7480%22 stroke-width=%222%22><path d=%22M2 4l4 4 4-4%22/></svg>') no-repeat right 12px center; border:1px solid var(--ol-border-strong); color:var(--ol-text); font-family:var(--ol-font-mono); font-size:12px; cursor:pointer; appearance:none; -webkit-appearance:none; -moz-appearance:none;">
          <option value="all">Any AI prevalence</option>
          {presentPrevs.map((p) => <option value={p}>{PREV[p].label} AI prevalence</option>)}
        </select>
        {taintCount > 0 && (
          <button id="rule-flow" type="button" aria-pressed="false" title="Show only dataflow (taint) rules — those that trace source to sink" style="display:inline-flex; align-items:center; gap:7px; height:40px; padding:0 14px; background:transparent; border:1px solid var(--ol-border-strong); color:var(--ol-text-secondary); font-family:var(--ol-font-mono); font-size:12px; font-weight:600; letter-spacing:0.04em; cursor:pointer; transition:all var(--ol-dur-fast) var(--ol-ease-standard);">
            <svg width="18" height="11" viewBox="0 0 20 12" fill="none" aria-hidden="true"><circle cx="3" cy="6" r="2.2" fill="currentColor"></circle><path d="M5.4 6h8.2" stroke="currentColor" stroke-width="1.3"></path><path d="M12.6 2.6L16.4 6l-3.8 3.4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" fill="none"></path></svg>
            DATAFLOW
          </button>
        )}
      </div>

      <!-- SEVERITY CHIPS -->
      <div style="display:flex; flex-wrap:wrap; gap:8px; margin-bottom:var(--ol-space-5);" role="group" aria-label="Filter by severity">
        <button type="button" data-sev="all" aria-pressed="true" style="display:inline-flex; align-items:center; gap:7px; font-family:var(--ol-font-mono); font-size:11px; font-weight:600; letter-spacing:0.04em; padding:6px 12px; cursor:pointer; color:var(--ol-accent-fg); background:var(--ol-accent); border:1px solid var(--ol-accent); transition:all var(--ol-dur-fast) var(--ol-ease-standard);">ALL</button>
        {presentSevs.map((s) => (
          <button
            type="button"
            data-sev={s}
            aria-pressed="false"
            style={`display:inline-flex; align-items:center; gap:7px; font-family:var(--ol-font-mono); font-size:11px; font-weight:600; letter-spacing:0.04em; padding:6px 12px; cursor:pointer; color:${SEV[s].color}; background:transparent; border:1px solid var(--ol-border-strong); transition:all var(--ol-dur-fast) var(--ol-ease-standard);`}
          >
            ● {SEV[s].label}
          </button>
        ))}
      </div>

      <div id="rule-count-label" style="font-family:var(--ol-font-mono); font-size:11px; color:var(--ol-text-muted); margin-bottom:var(--ol-space-3);">{rules.length} rules</div>

      <!-- TABLE -->
      <div style="border:1px solid var(--ol-border);">
        <div style="overflow-x:auto;">
          <table style="width:100%; border-collapse:collapse; font-size:var(--ol-text-body-s); min-width:640px;">
            <thead>
              <tr style="background:var(--ol-surface);">
                <th style="text-align:left; font-family:var(--ol-font-mono); font-size:10px; font-weight:600; letter-spacing:0.08em; color:var(--ol-text-muted); padding:11px 16px; border-bottom:1px solid var(--ol-border);">RULE</th>
                <th style="text-align:left; font-family:var(--ol-font-mono); font-size:10px; font-weight:600; letter-spacing:0.08em; color:var(--ol-text-muted); padding:11px 16px; border-bottom:1px solid var(--ol-border);">SEVERITY</th>
                <th style="text-align:left; font-family:var(--ol-font-mono); font-size:10px; font-weight:600; letter-spacing:0.08em; color:var(--ol-text-muted); padding:11px 16px; border-bottom:1px solid var(--ol-border);">CATEGORY</th>
                <th style="text-align:left; font-family:var(--ol-font-mono); font-size:10px; font-weight:600; letter-spacing:0.08em; color:var(--ol-text-muted); padding:11px 16px; border-bottom:1px solid var(--ol-border);" title="How often AI coding tools generate this anti-pattern by default">AI</th>
                <th style="text-align:left; font-family:var(--ol-font-mono); font-size:10px; font-weight:600; letter-spacing:0.08em; color:var(--ol-text-muted); padding:11px 16px; border-bottom:1px solid var(--ol-border);">LANG</th>
              </tr>
            </thead>
            <tbody id="rule-rows">
              {rules.map((r) => (
                <tr
                  data-row
                  data-id={r.id}
                  data-title={r.title.toLowerCase()}
                  data-sev={r.severity}
                  data-cat={r.category}
                  data-prev={r.llmPrevalence}
                  data-flow={isTaint(r.id) ? 'true' : 'false'}
                  data-langs={r.languages.join(' ')}
                  style="transition:background var(--ol-dur-fast) var(--ol-ease-standard); cursor:pointer;"
                  onclick={`location.href='/rules/${r.slug}'`}
                >
                  <td style={`padding:12px 16px; border-bottom:1px solid var(--ol-border-subtle); border-left:3px solid ${SEV[r.severity].color};`}>
                    <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap; margin-bottom:2px;">
                      <a href={`/rules/${r.slug}`} style="font-family:var(--ol-font-mono); font-size:12.5px; color:var(--ol-accent); text-decoration:none;">{r.id}</a>
                      {isTaint(r.id) && (
                        <span title="Dataflow rule — traces untrusted/sensitive data from source to a dangerous sink" style="display:inline-flex; align-items:center; gap:4px; font-family:var(--ol-font-mono); font-size:9px; font-weight:600; letter-spacing:0.06em; color:var(--ol-accent); border:1px solid var(--ol-accent-800); padding:1px 5px; line-height:1.4;">
                          <svg width="13" height="8" viewBox="0 0 20 12" fill="none" aria-hidden="true"><circle cx="3" cy="6" r="2.2" fill="currentColor"></circle><path d="M5.4 6h8.2" stroke="currentColor" stroke-width="1.6"></path><path d="M12.6 2.6L16.4 6l-3.8 3.4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"></path></svg>
                          DATAFLOW
                        </span>
                      )}
                    </div>
                    <div style="font-size:12.5px; color:var(--ol-text-secondary);">{r.title}</div>
                  </td>
                  <td style="padding:12px 16px; border-bottom:1px solid var(--ol-border-subtle); white-space:nowrap;">
                    <span style={`font-family:var(--ol-font-mono); font-size:10px; font-weight:600; color:${SEV[r.severity].color};`}>● {SEV[r.severity].label}</span>
                  </td>
                  <td style="padding:12px 16px; border-bottom:1px solid var(--ol-border-subtle);">
                    <span style="font-family:var(--ol-font-mono); font-size:11px; color:var(--ol-text-muted);">{r.category}</span>
                  </td>
                  <td style="padding:12px 16px; border-bottom:1px solid var(--ol-border-subtle); white-space:nowrap;">
                    <span title={`AI prevalence: ${PREV[r.llmPrevalence].label}`} style={`font-family:var(--ol-font-mono); font-size:10px; font-weight:600; letter-spacing:0.04em; color:${PREV[r.llmPrevalence].color};`}>● {PREV[r.llmPrevalence].label}</span>
                  </td>
                  <td style="padding:12px 16px; border-bottom:1px solid var(--ol-border-subtle);">
                    <span style="font-family:var(--ol-font-mono); font-size:11px; color:var(--ol-text-muted);">{r.languages.join(' · ')}</span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p id="rule-empty" hidden style="font-family:var(--ol-font-mono); font-size:12px; color:var(--ol-text-muted); padding:24px 16px; margin:0;">No rules match these filters.</p>
      </div>

      <!-- PAGINATION -->
      <div id="rule-pager" hidden style="display:flex; align-items:center; justify-content:center; gap:12px; margin-top:var(--ol-space-5);" role="navigation" aria-label="Rule pages">
        <button id="rule-prev" type="button" aria-label="Previous page" style="display:inline-flex; align-items:center; gap:7px; font-family:var(--ol-font-mono); font-size:11px; font-weight:600; letter-spacing:0.04em; padding:6px 12px; cursor:pointer; color:var(--ol-text-secondary); background:transparent; border:1px solid var(--ol-border-strong); transition:all var(--ol-dur-fast) var(--ol-ease-standard);">« PREV</button>
        <span id="rule-page-indicator" aria-live="polite" style="font-family:var(--ol-font-mono); font-size:11px; color:var(--ol-text-muted); min-width:90px; text-align:center;">Page 1 / 1</span>
        <button id="rule-next" type="button" aria-label="Next page" style="display:inline-flex; align-items:center; gap:7px; font-family:var(--ol-font-mono); font-size:11px; font-weight:600; letter-spacing:0.04em; padding:6px 12px; cursor:pointer; color:var(--ol-text-secondary); background:transparent; border:1px solid var(--ol-border-strong); transition:all var(--ol-dur-fast) var(--ol-ease-standard);">NEXT »</button>
      </div>
    </main>
  </SiteChrome>

  <script is:inline>
    (() => {
      const PAGE_SIZE = 12;
      const search = document.getElementById('rule-search');
      const langSel = document.getElementById('rule-lang');
      const catSel = document.getElementById('rule-cat');
      const prevSel = document.getElementById('rule-prevalence');
      const flowBtn = document.getElementById('rule-flow');
      const rows = Array.from(document.querySelectorAll('[data-row]'));
      const countLabel = document.getElementById('rule-count-label');
      const empty = document.getElementById('rule-empty');
      const chips = Array.from(document.querySelectorAll('[data-sev]'));
      const pager = document.getElementById('rule-pager');
      const prevBtn = document.getElementById('rule-prev');
      const nextBtn = document.getElementById('rule-next');
      const pageIndicator = document.getElementById('rule-page-indicator');
      let sev = 'all';
      let flowOnly = false;
      let page = 1;

      function matches(row) {
        const q = (search.value || '').trim().toLowerCase();
        const lang = langSel.value;
        const cat = catSel.value;
        const matchQ = !q || row.dataset.id.includes(q) || row.dataset.title.includes(q);
        const prev = prevSel.value;
        const matchLang = lang === 'all' || row.dataset.langs.split(' ').includes(lang);
        const matchCat = cat === 'all' || row.dataset.cat === cat;
        const matchSev = sev === 'all' || row.dataset.sev === sev;
        const matchPrev = prev === 'all' || row.dataset.prev === prev;
        const matchFlow = !flowOnly || row.dataset.flow === 'true';
        return matchQ && matchLang && matchCat && matchSev && matchPrev && matchFlow;
      }

      function setDisabled(btn, disabled) {
        btn.disabled = disabled;
        btn.setAttribute('aria-disabled', String(disabled));
        btn.style.cursor = disabled ? 'not-allowed' : 'pointer';
        btn.style.opacity = disabled ? '0.4' : '1';
      }

      // Filter, then paginate the filtered subset (12 per page).
      function render() {
        const filtered = rows.filter(matches);
        const total = filtered.length;
        const pageCount = Math.max(1, Math.ceil(total / PAGE_SIZE));
        if (page > pageCount) page = pageCount;
        if (page < 1) page = 1;
        const start = (page - 1) * PAGE_SIZE;
        const end = start + PAGE_SIZE;

        // Hide everything, then reveal only this page's slice of the filtered rows.
        for (const row of rows) row.hidden = true;
        for (let i = start; i < end && i < total; i++) filtered[i].hidden = false;

        countLabel.textContent = total + (total === 1 ? ' rule' : ' rules');
        empty.hidden = total !== 0;
        pager.hidden = total === 0;
        pageIndicator.textContent = 'Page ' + page + ' / ' + pageCount;
        setDisabled(prevBtn, page <= 1);
        setDisabled(nextBtn, page >= pageCount);
      }

      // Any filter change resets to page 1.
      function onFilterChange() {
        page = 1;
        render();
      }

      for (const chip of chips) {
        chip.addEventListener('click', () => {
          sev = chip.dataset.sev;
          for (const c of chips) {
            const active = c === chip;
            c.setAttribute('aria-pressed', String(active));
            c.style.background = active ? 'var(--ol-accent)' : 'transparent';
            c.style.borderColor = active ? 'var(--ol-accent)' : 'var(--ol-border-strong)';
            c.style.color = active
              ? 'var(--ol-accent-fg)'
              : c.dataset.sev === 'all'
                ? 'var(--ol-text-secondary)'
                : 'var(--ol-sev-' + c.dataset.sev + ')';
          }
          onFilterChange();
        });
      }

      prevBtn.addEventListener('click', () => {
        if (page > 1) {
          page--;
          render();
        }
      });
      nextBtn.addEventListener('click', () => {
        page++;
        render();
      });

      search.addEventListener('input', onFilterChange);
      langSel.addEventListener('change', onFilterChange);
      catSel.addEventListener('change', onFilterChange);
      prevSel.addEventListener('change', onFilterChange);

      // Dataflow toggle: an on/off chip that narrows to taint (source→sink) rules.
      if (flowBtn) {
        flowBtn.addEventListener('click', () => {
          flowOnly = !flowOnly;
          flowBtn.setAttribute('aria-pressed', String(flowOnly));
          flowBtn.style.background = flowOnly ? 'var(--ol-accent)' : 'transparent';
          flowBtn.style.borderColor = flowOnly ? 'var(--ol-accent)' : 'var(--ol-border-strong)';
          flowBtn.style.color = flowOnly ? 'var(--ol-accent-fg)' : 'var(--ol-text-secondary)';
          onFilterChange();
        });
      }

      // Rows navigate via onclick; some browsers keep the :active / tap-highlight
      // paint on the clicked row when it is restored from bfcache (Back button),
      // leaving it stuck under a solid accent fill with unreadable text. Mirror
      // the layout's stuck-hover reset: drop the lingering state on bfcache
      // events by blurring focus and clearing any transient inline background.
      const clearStuckRows = () => {
        if (document.activeElement instanceof HTMLElement) document.activeElement.blur();
        for (const row of rows) row.style.background = '';
      };
      window.addEventListener('pageshow', clearStuckRows);
      window.addEventListener('pagehide', clearStuckRows);

      render();
    })();
  </script>
</Base>

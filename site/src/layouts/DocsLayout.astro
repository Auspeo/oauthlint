---
import SiteChrome from '../components/SiteChrome.astro';
import Base from './Base.astro';

interface Props {
  frontmatter?: { title?: string; description?: string; section?: string };
  title?: string;
  description?: string;
  section?: string;
}

const fm = Astro.props.frontmatter ?? {};
const section = Astro.props.section ?? fm.section ?? '';
const title = `${Astro.props.title ?? fm.title ?? 'Docs'} — OAuthLint`;
const description = Astro.props.description ?? fm.description;

const NAV = [
  { key: 'getting-started', label: 'Getting started', href: '/docs' },
  { key: 'semgrep', label: 'Use with Semgrep', href: '/docs/semgrep' },
  { key: 'cli', label: 'CLI reference', href: '/docs/cli' },
  { key: 'configuration', label: 'Configuration', href: '/docs/configuration' },
  { key: 'github-action', label: 'GitHub Action', href: '/docs/github-action' },
  { key: 'pre-commit', label: 'pre-commit', href: '/docs/pre-commit' },
  { key: 'recipes', label: 'Recipes', href: '/docs/recipes' },
  { key: 'vscode', label: 'VS Code extension', href: '/docs/vscode' },
  { key: 'suppressing', label: 'Suppressing rules', href: '/docs/suppressing' },
];
---

<Base title={title} description={description}>
  <SiteChrome active="docs">
    <div class="docs-wrap">
      <aside class="docs-side" aria-label="Documentation">
        <div class="docs-eyebrow">DOCUMENTATION</div>
        <nav>
          {
            NAV.map((item) => (
              <a
                href={item.href}
                aria-current={section === item.key ? 'page' : undefined}
                class:list={['docs-link', { active: section === item.key }]}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </aside>
      <main class="prose">
        <slot />
      </main>
    </div>
  </SiteChrome>
</Base>

<style is:global>
  .docs-wrap {
    max-width: 1120px;
    margin: 0 auto;
    padding: var(--ol-space-12) var(--ol-space-6) var(--ol-space-24);
    display: grid;
    grid-template-columns: 208px minmax(0, 1fr);
    gap: var(--ol-space-12);
    align-items: start;
  }
  .docs-side {
    position: sticky;
    top: 72px;
  }
  .docs-eyebrow {
    font-family: var(--ol-font-mono);
    font-size: var(--ol-text-label);
    letter-spacing: var(--ol-tracking-wide);
    color: var(--ol-text-faint);
    margin: 0 0 var(--ol-space-4) var(--ol-space-3);
  }
  .docs-side nav {
    display: flex;
    flex-direction: column;
    border-left: 1px solid var(--ol-border);
  }
  .docs-link {
    font-family: var(--ol-font-mono);
    font-size: 14px;
    color: var(--ol-text-muted);
    text-decoration: none;
    padding: 6px 12px;
    border-left: 2px solid transparent;
    margin-left: -1px;
    transition: color var(--ol-dur-fast) var(--ol-ease-standard);
  }
  .docs-link:hover {
    color: var(--ol-text);
  }
  .docs-link.active {
    color: var(--ol-accent);
    border-left-color: var(--ol-accent);
    background: var(--ol-accent-subtle);
  }
  @media (max-width: 820px) {
    .docs-wrap {
      /* minmax(0,1fr) (not 1fr) so a wide <pre>/<table> scrolls inside the
         content column instead of stretching the grid past the viewport. */
      grid-template-columns: minmax(0, 1fr);
      gap: var(--ol-space-6);
    }
    .docs-side {
      position: static;
    }
    .docs-side nav {
      flex-flow: row wrap;
      border-left: none;
    }
    .docs-link {
      border-left: none;
      margin-left: 0;
      border: 1px solid var(--ol-border);
    }
    .docs-link.active {
      border-color: var(--ol-accent);
    }
  }

  /* Prose — shared with the Validation page styling. */
  .prose {
    min-width: 0;
    color: var(--ol-text-secondary);
    font-family: var(--ol-font-ui);
    font-size: var(--ol-text-body-l);
    line-height: var(--ol-leading-relaxed);
  }
  .prose > :first-child {
    margin-top: 0;
  }
  .prose h1 {
    font-family: var(--ol-font-display);
    font-size: var(--ol-text-display-m);
    font-weight: var(--ol-weight-bold);
    letter-spacing: var(--ol-tracking-tight);
    line-height: var(--ol-leading-tight);
    color: var(--ol-text);
    margin: 0 0 var(--ol-space-4);
  }
  .prose .lede,
  .prose h1 + p {
    font-size: var(--ol-text-body-l);
    color: var(--ol-text-muted);
    margin: 0 0 var(--ol-space-8);
  }
  .prose h2 {
    font-family: var(--ol-font-display);
    font-size: var(--ol-text-heading-l);
    font-weight: var(--ol-weight-semibold);
    letter-spacing: var(--ol-tracking-snug);
    color: var(--ol-text);
    margin: var(--ol-space-12) 0 var(--ol-space-4);
    padding-top: var(--ol-space-4);
    border-top: 1px solid var(--ol-border-subtle);
    scroll-margin-top: 80px;
  }
  .prose h3 {
    font-size: var(--ol-text-heading-m);
    font-weight: var(--ol-weight-semibold);
    color: var(--ol-text);
    margin: var(--ol-space-8) 0 var(--ol-space-3);
    scroll-margin-top: 80px;
  }
  .prose p,
  .prose li {
    margin: 0 0 var(--ol-space-3);
  }
  .prose ul,
  .prose ol {
    padding-left: var(--ol-space-6);
    margin: 0 0 var(--ol-space-4);
  }
  .prose a {
    color: var(--ol-accent);
    text-decoration: none;
  }
  .prose a:hover {
    text-decoration: underline;
  }
  .prose strong {
    color: var(--ol-text);
    font-weight: var(--ol-weight-semibold);
  }
  .prose code {
    font-family: var(--ol-font-mono);
    font-size: var(--ol-text-code);
    background: var(--ol-surface);
    border: 1px solid var(--ol-border-subtle);
    border-radius: var(--ol-radius-xs);
    padding: 1px 5px;
    color: var(--ol-text);
  }
  .prose pre {
    background: var(--ol-code-bg);
    border: 1px solid var(--ol-code-border);
    border-radius: var(--ol-radius-md);
    padding: var(--ol-space-4);
    overflow-x: auto;
    margin: 0 0 var(--ol-space-4);
  }
  .prose pre code {
    background: none;
    border: none;
    padding: 0;
    color: var(--ol-text-secondary);
    font-size: var(--ol-text-code);
  }
  .prose blockquote {
    margin: 0 0 var(--ol-space-4);
    padding: var(--ol-space-2) var(--ol-space-4);
    border-left: 2px solid var(--ol-accent-border);
    color: var(--ol-text-muted);
    background: var(--ol-surface);
  }
  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 var(--ol-space-4);
    font-size: var(--ol-text-body-m);
  }
  .prose th,
  .prose td {
    text-align: left;
    padding: var(--ol-space-2) var(--ol-space-3);
    border: 1px solid var(--ol-border);
  }
  .prose th {
    color: var(--ol-text);
    font-family: var(--ol-font-mono);
    font-size: var(--ol-text-label);
  }
  .prose hr {
    border: none;
    border-top: 1px solid var(--ol-border-subtle);
    margin: var(--ol-space-8) 0;
  }
  /* Wide docs tables scroll horizontally on phones instead of overflowing. */
  @media (max-width: 640px) {
    .prose table {
      display: block;
      overflow-x: auto;
      width: 100%;
    }
  }
</style>

---
import '../styles/tokens.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'A static-analysis linter for the OAuth, OIDC, JWT, session and CORS anti-patterns AI coding tools generate by default. Hand-curated rules, zero false positives on clean auth libraries. Open source, MIT.',
  ogImage = '/og.png',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://oauthlint.dev').href;
const ogUrl = new URL(ogImage, Astro.site ?? 'https://oauthlint.dev').href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#0E1113" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogUrl} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=Hanken+Grotesk:wght@400;500;600;700&family=Martian+Mono:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />

    <!-- Progressive enhancement: the ported design uses `style-hover="…"` (a
         Cloud Design canvas attribute that isn't real CSS). Replicate it as a
         real MOUSE hover. Mouse-only on purpose: applying it on focus made the
         style stick after click+back (the clicked link kept focus and the
         hover style persisted through bfcache). Keyboard focus is handled by the
         global :focus-visible outline. We also reset on bfcache restore so a
         hover interrupted by navigation never sticks. No JS = no hover, but
         fully functional. -->
    <script>
      const items = [...document.querySelectorAll<HTMLElement>('[style-hover]')].map((el) => ({
        el,
        base: el.getAttribute('style') ?? '',
        hover: el.getAttribute('style-hover') ?? '',
      }));
      const reset = () => {
        for (const i of items) i.el.style.cssText = i.base;
      };
      for (const i of items) {
        i.el.addEventListener('mouseenter', () => {
          i.el.style.cssText = `${i.base};${i.hover}`;
        });
        i.el.addEventListener('mouseleave', () => {
          i.el.style.cssText = i.base;
        });
      }
      // Navigation can skip mouseleave; clear any stuck hover on bfcache events.
      window.addEventListener('pageshow', reset);
      window.addEventListener('pagehide', reset);
    </script>
  </body>
</html>

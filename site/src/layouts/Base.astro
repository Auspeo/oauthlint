---
import '../styles/tokens.css';
import '../styles/global.css';
import AnnouncementBar from '../components/AnnouncementBar.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'A static-analysis linter for the OAuth, OIDC, JWT, session and CORS anti-patterns AI coding tools generate by default. Hand-curated rules, zero false positives on clean auth libraries. Open source, MIT.',
  ogImage = '/og.png',
} = Astro.props;

const site = Astro.site?.href ?? 'https://oauthlint.dev/';
const canonical = new URL(Astro.url.pathname, site).href;
const ogUrl = new URL(ogImage, site).href;

// Site-wide structured data (Organization + WebSite + the tool as SoftwareApplication).
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${site}#org`,
      name: 'Auspeo',
      url: site,
      logo: new URL('/og.png', site).href,
    },
    {
      '@type': 'WebSite',
      '@id': `${site}#website`,
      url: site,
      name: 'OAuthLint',
      description:
        'A static-analysis linter for the OAuth, OIDC, JWT, session and CORS anti-patterns AI coding tools generate.',
      publisher: { '@id': `${site}#org` },
    },
    {
      '@type': 'SoftwareApplication',
      name: 'OAuthLint',
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'Cross-platform',
      url: site,
      description:
        'Open-source Semgrep-based linter that catches the OAuth/OIDC/JWT/session/CORS anti-patterns AI coding tools generate. CLI + GitHub Action + VS Code, across JS/TS, Python, Go, Java and Rust.',
      license: 'https://opensource.org/licenses/MIT',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      publisher: { '@id': `${site}#org` },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#0E1113" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />

    <!-- Set the colour theme BEFORE first paint to avoid a flash. Dark is the
         brand default when there's no stored choice or OS-preference signal. -->
    <script is:inline>
      // Mark JS available before first paint so scroll-reveal styles only apply
      // when we can actually reveal them (no-JS = content visible, no flash).
      document.documentElement.classList.add('js');
      // Set the theme before first paint (no flash): a stored choice wins, else
      // follow the OS, else dark (the brand default). Light is the designed second
      // theme; the nav toggle flips and persists it.
      try {
        const stored = localStorage.getItem('ol-theme');
        document.documentElement.dataset.theme =
          stored ?? (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
      } catch {
        document.documentElement.dataset.theme = 'dark';
      }
    </script>

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogUrl} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=Hanken+Grotesk:wght@400;500;600;700&family=Martian+Mono:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Release announcement bar: slim, dismissible, above the nav on every
         page. Config-driven from src/data/announcement.ts (renders nothing when
         that exports null). Mounted here so it wraps both the captured marketing
         partials and the Astro app pages. -->
    <AnnouncementBar />
    <slot />

    <!-- Progressive enhancement: the ported design uses `style-hover="…"` (a
         Cloud Design canvas attribute that isn't real CSS). Replicate it as a
         real MOUSE hover. Mouse-only on purpose: applying it on focus made the
         style stick after click+back (the clicked link kept focus and the
         hover style persisted through bfcache). Keyboard focus is handled by the
         global :focus-visible outline. We also reset on bfcache restore so a
         hover interrupted by navigation never sticks. No JS = no hover, but
         fully functional. -->
    <script>
      const items = [...document.querySelectorAll<HTMLElement>('[style-hover]')].map((el) => ({
        el,
        base: el.getAttribute('style') ?? '',
        hover: el.getAttribute('style-hover') ?? '',
      }));
      const reset = () => {
        for (const i of items) i.el.style.cssText = i.base;
      };
      for (const i of items) {
        i.el.addEventListener('mouseenter', () => {
          i.el.style.cssText = `${i.base};${i.hover}`;
        });
        i.el.addEventListener('mouseleave', () => {
          i.el.style.cssText = i.base;
        });
      }
      // Navigation can skip mouseleave; clear any stuck hover on bfcache events.
      window.addEventListener('pageshow', reset);
      window.addEventListener('pagehide', reset);
    </script>

    <!-- Theme toggle. The nav markup (SiteChrome + the captured partials) ships
         a `[data-theme-toggle]` button with a `[data-theme-icon]` glyph. The
         pre-paint inline script in <head> already set the theme; here we just
         sync the icon and wire the click. Lives in the layout so it runs on
         every page, including the `set:html` partials whose own scripts don't
         execute. -->
    <script>
      const ICON = { dark: '◐', light: '◑' };
      const apply = (theme: string) => {
        document.documentElement.dataset.theme = theme;
        for (const icon of document.querySelectorAll<HTMLElement>('[data-theme-icon]')) {
          icon.textContent = ICON[theme as keyof typeof ICON] ?? ICON.dark;
        }
        for (const btn of document.querySelectorAll<HTMLElement>('[data-theme-toggle]')) {
          btn.setAttribute('aria-pressed', String(theme === 'light'));
        }
      };
      const syncIcon = () => apply(document.documentElement.dataset.theme || 'dark');
      for (const btn of document.querySelectorAll<HTMLElement>('[data-theme-toggle]')) {
        btn.addEventListener('click', () => {
          const next = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
          try {
            localStorage.setItem('ol-theme', next);
          } catch {
            /* private mode: still toggle for the session */
          }
          apply(next);
        });
      }
      syncIcon();
      window.addEventListener('pageshow', syncIcon);
    </script>

    <!-- Mobile navigation toggle. Below 920px the nav links collapse into a
         disclosure panel ([data-navlinks]) opened by the hamburger button
         ([data-nav-toggle]). Lives in the layout so it also wires the set:html
         partials (index/about), whose own scripts never run. Accessible: the
         button owns aria-expanded; Escape, outside-click and a tapped link all
         close the panel; resizing back to desktop resets state. -->
    <script>
      for (const toggle of document.querySelectorAll<HTMLElement>('[data-nav-toggle]')) {
        const nav = toggle.closest('nav');
        const panel = nav?.querySelector<HTMLElement>('[data-navlinks]');
        if (!panel) continue;

        const setOpen = (open: boolean) => {
          panel.classList.toggle('open', open);
          toggle.setAttribute('aria-expanded', String(open));
          toggle.setAttribute('aria-label', open ? 'Close navigation menu' : 'Open navigation menu');
        };
        const close = () => setOpen(false);

        toggle.addEventListener('click', (e) => {
          e.stopPropagation();
          setOpen(!panel.classList.contains('open'));
        });
        // A tapped link navigates; collapse the panel so it never lingers.
        for (const a of panel.querySelectorAll('a')) a.addEventListener('click', close);
        // Click / tap outside the open panel closes it.
        document.addEventListener('click', (e) => {
          if (!panel.classList.contains('open')) return;
          const t = e.target as Node;
          if (!panel.contains(t) && !toggle.contains(t)) close();
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && panel.classList.contains('open')) {
            close();
            toggle.focus();
          }
        });
        // Returning to desktop width: drop the open state (CSS shows links inline).
        window.matchMedia('(min-width: 921px)').addEventListener('change', (e) => {
          if (e.matches) close();
        });
        // Never leave the panel stuck open across bfcache navigations.
        window.addEventListener('pageshow', close);
      }
    </script>

    <!-- Scroll reveal: sections fade up as they enter the viewport. One restrained
         motion idea, not scattered effects. Gated on prefers-reduced-motion and on
         IntersectionObserver; the `html.js section` CSS only hides when JS is on, so
         no-JS renders everything visible. Above-the-fold sections reveal on load. -->
    <script>
      const sections = document.querySelectorAll('section');
      const motionOk = window.matchMedia('(prefers-reduced-motion: no-preference)').matches;
      const revealAll = () => {
        for (const s of sections) s.classList.add('is-visible');
      };
      if (motionOk && 'IntersectionObserver' in window && sections.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          // threshold 0 reveals as soon as any pixel enters the viewport, so a
          // section can never get stuck hidden (a negative bottom margin could).
          { threshold: 0 },
        );
        for (const s of sections) io.observe(s);
        // Failsafe: nothing should ever stay invisible if the observer misfires.
        window.addEventListener('load', () => setTimeout(revealAll, 2500));
      } else {
        revealAll();
      }
    </script>

    <!-- Hero terminal scan demo: types the command, spins, then streams the
         findings — looping while it's in view. Ported from the original docs
         ScanDemo. Lives in the layout because the hero is a set:html partial
         whose own scripts don't run. Pauses off-screen; under reduced motion (or
         no IntersectionObserver) it just shows the finished output. -->
    <script>
      (() => {
        const term = document.querySelector('[data-term]');
        if (!term) return;
        const CMD = 'npx oauthlint scan ./src';
        const SPIN = ['⠋', '⠙', '⠹', '⠸', '⠼', '⠴', '⠦', '⠧', '⠇', '⠏'];
        const cmd = term.querySelector('[data-term-cmd]');
        const caret = term.querySelector('[data-term-caret]');
        const status = term.querySelector('[data-term-status]');
        const spin = term.querySelector('[data-term-spin]');
        const finds = [...term.querySelectorAll('[data-term-find]')];
        const sum = term.querySelector('[data-term-sum]');

        const showFinal = () => {
          cmd.textContent = CMD;
          caret.style.display = 'none';
          status.style.opacity = '0';
          for (const f of finds) {
            f.style.opacity = '1';
            f.style.transform = 'none';
          }
          sum.style.opacity = '1';
        };
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce || !('IntersectionObserver' in window)) {
          showFinal();
          return;
        }

        let gen = 0;
        let running = false;
        let spinTimer = null;
        const timers = new Set();
        const wait = (ms) =>
          new Promise((res) => {
            const t = setTimeout(() => {
              timers.delete(t);
              res();
            }, ms);
            timers.add(t);
          });
        const reset = () => {
          cmd.textContent = '';
          caret.style.display = '';
          status.style.opacity = '0';
          sum.style.opacity = '0';
          for (const f of finds) {
            f.style.opacity = '0';
            f.style.transform = 'translateY(4px)';
          }
        };

        async function loop(my) {
          while (running && my === gen) {
            reset();
            await wait(550);
            for (let i = 1; i <= CMD.length && my === gen; i++) {
              cmd.textContent = CMD.slice(0, i);
              await wait(32);
            }
            if (my !== gen) return;
            await wait(320);
            status.style.opacity = '1';
            spinTimer = setInterval(() => {
              const next = (SPIN.indexOf(spin.textContent) + 1) % SPIN.length;
              spin.textContent = SPIN[next];
            }, 80);
            await wait(1150);
            clearInterval(spinTimer);
            spinTimer = null;
            status.style.opacity = '0';
            if (my !== gen) return;
            for (let i = 0; i < finds.length && my === gen; i++) {
              finds[i].style.opacity = '1';
              finds[i].style.transform = 'none';
              await wait(340);
            }
            if (my !== gen) return;
            await wait(160);
            sum.style.opacity = '1';
            caret.style.display = 'none';
            await wait(4800);
          }
        }
        const start = () => {
          if (running) return;
          running = true;
          gen += 1;
          loop(gen);
        };
        const stop = () => {
          running = false;
          gen += 1;
          if (spinTimer) {
            clearInterval(spinTimer);
            spinTimer = null;
          }
          for (const t of timers) clearTimeout(t);
          timers.clear();
        };
        new IntersectionObserver(
          (entries) => {
            for (const e of entries) (e.isIntersecting ? start() : stop());
          },
          { threshold: 0.3 },
        ).observe(term);
      })();
    </script>
  </body>
</html>

---
/**
 * Shared site chrome (sticky nav + footer + the graphite grid backdrop)
 * used by the rule catalogue and per-rule pages. Replicates the structure +
 * inline-token styling of the ported Cloud Design pages, minus the canvas-only
 * `style-hover` attributes.
 */
interface Props {
  /** Which nav link is the current page, so it renders in the accent colour. */
  active?: 'docs' | 'rules' | 'research' | 'validation' | 'about';
}
const { active } = Astro.props;
const year = new Date().getFullYear();
const navLink = (key: string) => (active === key ? 'var(--ol-accent)' : 'var(--ol-text-muted)');
---
<div
  style="min-height:100vh; background-color:var(--ol-canvas); background-image:linear-gradient(to right, var(--ol-grid-line) 1px, transparent 1px), linear-gradient(to bottom, var(--ol-grid-line) 1px, transparent 1px); background-size:32px 32px;"
>
  <nav
    style="position:sticky; top:0; z-index:50; display:flex; align-items:center; gap:var(--ol-space-6); padding:0 var(--ol-space-6); height:56px; background:color-mix(in oklch, var(--ol-canvas) 88%, transparent); backdrop-filter:blur(12px); border-bottom:1px solid var(--ol-border);"
  >
    <a href="/" style="display:flex; align-items:center; gap:10px; text-decoration:none; color:var(--ol-text);" aria-label="OAuthLint home">
      <svg width="24" height="24" viewBox="0 0 64 64" fill="none" aria-hidden="true"><rect x="13" y="11" width="38" height="27" stroke="var(--ol-accent)" stroke-width="5"/><path d="M11 50c3-5 6-5 9 0s6 5 9 0 6-5 9 0 6 5 9 0" stroke="var(--ol-sev-critical)" stroke-width="5" stroke-linecap="round"/></svg>
      <span style="font-family:var(--ol-font-display); font-weight:700; font-size:15px; letter-spacing:-0.02em;">OAuthLint</span>
    </a>
    <div style="flex:1;"></div>
    <div id="site-nav-links" data-navlinks style="display:flex; gap:var(--ol-space-6); align-items:center;">
      <a href="/docs" style={`font-family:var(--ol-font-ui); font-size:15px; color:${navLink('docs')}; text-decoration:none;`}>docs</a>
      <a href="/rules" style={`font-family:var(--ol-font-ui); font-size:15px; color:${navLink('rules')}; text-decoration:none;`}>rules</a>
      <a href="/research" style={`font-family:var(--ol-font-ui); font-size:15px; color:${navLink('research')}; text-decoration:none;`}>research</a>
      <a href="/validation" style={`font-family:var(--ol-font-ui); font-size:15px; color:${navLink('validation')}; text-decoration:none;`}>validation</a>
      <a href="/about" style={`font-family:var(--ol-font-ui); font-size:15px; color:${navLink('about')}; text-decoration:none;`}>about</a>
    </div>
    <button type="button" data-nav-toggle aria-label="Open navigation menu" aria-expanded="false" aria-controls="site-nav-links">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <button type="button" data-theme-toggle aria-label="Toggle colour theme" style="display:inline-flex; align-items:center; justify-content:center; width:32px; height:32px; padding:0; background:var(--ol-surface); border:1px solid var(--ol-border-strong); color:var(--ol-text-secondary); cursor:pointer; transition:border-color var(--ol-dur-fast) var(--ol-ease-standard);"><span data-theme-icon aria-hidden="true" style="font-family:var(--ol-font-mono); font-size:14px; line-height:1;">◐</span></button>
    <a href="https://github.com/Auspeo/oauthlint" target="_blank" rel="noopener noreferrer" style="display:inline-flex; align-items:center; gap:8px; height:32px; padding:0 12px; background:var(--ol-surface); border:1px solid var(--ol-border-strong); font-family:var(--ol-font-mono); font-size:12px; color:var(--ol-text-secondary); text-decoration:none;">GitHub ↗</a>
  </nav>

  <slot />

  <footer style="border-top:1px solid var(--ol-border); background:var(--ol-canvas);">
    <div style="max-width:1120px; margin:0 auto; padding:var(--ol-space-8) var(--ol-space-6); display:flex; flex-wrap:wrap; gap:12px; justify-content:space-between; align-items:center;">
      <span style="font-family:var(--ol-font-mono); font-size:11px; color:var(--ol-text-faint);">© {year} OAuthLint</span>
      <div style="display:flex; gap:var(--ol-space-5);">
        <a href="/docs" style="font-family:var(--ol-font-ui); font-size:12px; color:var(--ol-text-muted); text-decoration:none;">docs</a>
        <a href="/research" style="font-family:var(--ol-font-ui); font-size:12px; color:var(--ol-text-muted); text-decoration:none;">research</a>
        <a href="/validation" style="font-family:var(--ol-font-ui); font-size:12px; color:var(--ol-text-muted); text-decoration:none;">validation</a>
        <a href="https://github.com/Auspeo/oauthlint" target="_blank" rel="noopener noreferrer" style="font-family:var(--ol-font-ui); font-size:12px; color:var(--ol-text-muted); text-decoration:none;">github ↗</a>
      </div>
    </div>
  </footer>
</div>

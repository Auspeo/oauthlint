{
  "name": "oauthlint-vscode",
  "private": true,
  "displayName": "oauthlint",
  "description": "Catch the OAuth/OIDC/JWT anti-patterns AI coding tools produce, right inside VS Code.",
  "version": "0.6.0",
  "icon": "icon.png",
  "publisher": "auspeo",
  "type": "commonjs",
  "galleryBanner": {
    "color": "#0C0E13",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.95.0",
    "node": ">=20.0.0"
  },
  "main": "./dist/extension.js",
  "categories": ["Linters", "Other"],
  "keywords": [
    "oauthlint",
    "oauth",
    "oidc",
    "jwt",
    "security",
    "appsec",
    "sast",
    "linter",
    "semgrep",
    "ai-code",
    "vibe-coding"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "contributes": {
    "configuration": {
      "title": "OAuthLint",
      "properties": {
        "oauthlint.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Run OAuthLint on save."
        },
        "oauthlint.minSeverity": {
          "type": "string",
          "enum": ["INFO", "LOW", "MEDIUM", "HIGH", "CRITICAL"],
          "default": "MEDIUM",
          "description": "Only surface findings at this severity or above."
        },
        "oauthlint.rulesDir": {
          "type": "string",
          "default": "",
          "description": "Override the rules directory used for scanning. Empty = the rule pack bundled with the extension."
        },
        "oauthlint.enginePath": {
          "type": "string",
          "default": "",
          "description": "Path to an existing opengrep or semgrep binary to use as the scan engine. Empty = download and manage Opengrep automatically (a one-time ~41 MB download on first scan)."
        }
      }
    },
    "commands": [
      {
        "command": "oauthlint.scanFile",
        "title": "OAuthLint: Scan current file",
        "category": "OAuthLint"
      },
      {
        "command": "oauthlint.scanWorkspace",
        "title": "OAuthLint: Scan workspace",
        "category": "OAuthLint"
      },
      {
        "command": "oauthlint.openDoc",
        "title": "OAuthLint: Open rule documentation",
        "category": "OAuthLint"
      },
      {
        "command": "oauthlint.retryEngineSetup",
        "title": "OAuthLint: Retry scan engine setup",
        "category": "OAuthLint"
      }
    ]
  },
  "scripts": {
    "build": "pnpm --filter oauthlint-rules --filter oauthlint run build && node esbuild.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "oauthlint": "workspace:*",
    "oauthlint-rules": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/vscode": "1.95.0",
    "esbuild": "0.25.12",
    "typescript": "5.7.3",
    "vitest": "2.1.9"
  },
  "license": "MIT",
  "author": "Auspeo (https://github.com/Auspeo)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Auspeo/oauthlint.git",
    "directory": "vscode"
  },
  "homepage": "https://oauthlint.dev",
  "bugs": "https://github.com/Auspeo/oauthlint/issues"
}

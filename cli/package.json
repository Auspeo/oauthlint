{
  "name": "oauthlint",
  "version": "0.10.1",
  "description": "Catch the OAuth/OIDC/JWT anti-patterns AI coding tools systematically produce. CLI wrapper around the oauthlint-rules Semgrep rule pack.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "oauthlint": "./bin/oauthlint.js"
  },
  "files": ["dist", "bin", "README.md", "LICENSE"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "start": "node bin/oauthlint.js"
  },
  "keywords": [
    "oauthlint",
    "semgrep",
    "oauth",
    "oauth2",
    "oidc",
    "jwt",
    "pkce",
    "security",
    "appsec",
    "sast",
    "static-analysis",
    "linter",
    "devsecops",
    "cli",
    "github-action",
    "code-scanning",
    "ai-code",
    "vibe-coding"
  ],
  "dependencies": {
    "commander": "15.0.0",
    "cosmiconfig": "9.0.2",
    "execa": "9.6.1",
    "oauthlint-rules": "workspace:*",
    "picocolors": "1.1.1",
    "yaml": "2.9.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "typescript": "5.7.3",
    "vitest": "2.1.9"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Auspeo/oauthlint.git",
    "directory": "cli"
  },
  "homepage": "https://oauthlint.dev",
  "bugs": "https://github.com/Auspeo/oauthlint/issues",
  "license": "MIT",
  "author": "Auspeo (https://github.com/Auspeo)",
  "engines": {
    "node": ">=20.0.0"
  }
}

{
  "name": "oauthlint-action",
  "version": "0.2.0",
  "private": true,
  "description": "Docker-based GitHub Action wrapping oauthlint.",
  "type": "module",
  "scripts": {
    "build": "echo 'no build — Docker image is built by GitHub at runtime' && exit 0",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "typescript": "5.7.3",
    "vitest": "2.1.9",
    "yaml": "2.6.1"
  },
  "license": "MIT"
}
